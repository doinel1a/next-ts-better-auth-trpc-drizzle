    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "drizzle-seed": "0.3.1",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.75.0",
    "server-only": "0.0.1",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
