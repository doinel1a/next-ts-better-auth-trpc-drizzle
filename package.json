  "scripts": {
    "postinstall": "husky & playwright install",
    "dev": "next dev",
    "build": "next build",
    "preview": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:profiling": "cross-env TIMING=all eslint",
    "format": "prettier --write **/**/*.{html,css,scss,js,jsx,cjs,mjs,ts,tsx,mdx} --cache",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "ba:generate": "npx @better-auth/cli generate --config ./src/lib/auth/index.ts",
    "db:studio": "drizzle-kit --config=drizzle/config.ts studio",
    "db:push": "drizzle-kit --config=drizzle/config.ts push",
    "db:create-migration": "drizzle-kit --config=drizzle/config.ts generate",
    "db:migrate": "drizzle-kit --config=drizzle/config.ts migrate",
    "db:seed": "cross-env SKIP_ENV_VALIDATION=true tsx drizzle/seeders/index.ts",
    "db-danger:reset": "cross-env SKIP_ENV_VALIDATION=true tsx drizzle/seeders/reset.ts"
  },
  "dependencies": {
